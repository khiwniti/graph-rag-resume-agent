# Required API Tokens
GITHUB_TOKEN=ghp_your_github_token_here
VERCEL_TOKEN=vcp_your_vercel_token_here
CLOUDFLARE_TOKEN=cfat_your_cloudflare_token_here
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Embedding model (default: all-MiniLM-L6-v2)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Optional: Collection limits (0 = unlimited)
MAX_REPOS=0
MAX_FILES_PER_REPO=50
MAX_FILE_BYTES=50000
MAX_COMMITS_PER_REPO=30

# Optional: Conversation artifact path
CONVERSATION_ZIP_PATH=conversation_acc97712a9c1482992c7523a4ed73e08.zip

# Optional: Output paths
GRAPH_OUTPUT_PATH=data/graph/knowledge_graph.json
VECTOR_INDEX_PATH=data/embeddings/faiss_index

# Data directory (default: data)
DATA_DIR=data
