# =============================================================================
# Required API Tokens
# =============================================================================
GITHUB_TOKEN=ghp_your_github_token_here
VERCEL_TOKEN=vcp_your_vercel_token_here
CLOUDFLARE_TOKEN=cfat_your_cloudflare_token_here
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here

# =============================================================================
# Neo4j Configuration
# =============================================================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# =============================================================================
# Optional: LLM & Embedding
# =============================================================================
OPENAI_API_KEY=your_openai_api_key_here
NVIDIA_API_KEY=your_nvidia_api_key_here
EMBEDDING_MODEL=all-MiniLM-L6-v2

# =============================================================================
# Collection Limits (0 = unlimited)
# =============================================================================
MAX_REPOS=0
MAX_FILES_PER_REPO=50
MAX_FILE_BYTES=50000
MAX_COMMITS_PER_REPO=30

# =============================================================================
# Ingestion Behavior
# =============================================================================
# Minimum free disk space (GB) before allowing new repo clones
MIN_FREE_DISK_GB=5.0
# Include forked repositories in GitHub collection
INCLUDE_FORKS=false
# Enable conversation artifact collection (disabled by default)
ENABLE_CONVERSATION_COLLECTOR=false

# =============================================================================
# Output Paths
# =============================================================================
DATA_DIR=data
GRAPH_OUTPUT_PATH=data/graph/knowledge_graph.json
VECTOR_INDEX_PATH=data/embeddings/faiss_index
